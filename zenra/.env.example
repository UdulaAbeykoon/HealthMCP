# ── Zenra environment ── copy to .env.local and fill in your own keys ──
# AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Voice (https://elevenlabs.io) — free tier works with premade voices
ELEVENLABS_API_KEY=

# Token vault (any base64 32-byte string)
TOKEN_ENCRYPTION_KEY=

# Google Calendar OAuth (https://console.cloud.google.com)
# Add http://localhost:3000/api/calendar/callback to the client's redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# Slack (https://api.slack.com/apps) — needs chat:write, channels:read, dnd:write
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Strava (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# App
APP_BASE_URL=http://localhost:3000
